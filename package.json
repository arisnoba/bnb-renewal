{
  "name": "bnb-renewal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "payload": "node --env-file=.env.local ./node_modules/payload/bin.js",
    "payload:generate-types": "node --env-file=.env.local ./node_modules/payload/bin.js generate:types",
    "payload:generate-importmap": "node --env-file=.env.local ./node_modules/payload/bin.js generate:importmap",
    "db:migrate": "node --env-file=.env.local ./node_modules/payload/bin.js migrate",
    "db:migrate:create": "node --env-file=.env.local ./node_modules/payload/bin.js migrate:create",
    "db:seed:p0-dry-run": "node --env-file=.env.local --import tsx scripts/seed-p0.ts --dry-run",
    "db:seed:p0-sample": "node --env-file=.env.local --import tsx scripts/seed-p0.ts --limit 3",
    "db:seed:p0-teachers": "node --env-file=.env.local --import tsx scripts/seed-p0.ts --only teachers --teacher-limit all",
    "db:seed:p0-teachers:dry-run": "node --env-file=.env.local --import tsx scripts/seed-p0.ts --dry-run --only teachers --teacher-limit all",
    "db:seed:p1-sample": "node --env-file=.env.local --import tsx scripts/seed-p1.ts --limit 10",
    "db:seed:p1-profiles": "node --env-file=.env.local --import tsx scripts/seed-p1.ts --only profiles --limit 50",
    "db:seed:p1-profiles:dry-run": "node --env-file=.env.local --import tsx scripts/seed-p1.ts --dry-run --only profiles --limit 50",
    "db:seed:p1-agencies": "node --env-file=.env.local --import tsx scripts/seed-p1.ts --only agencies --agency-limit all",
    "db:seed:p1-agencies:dry-run": "node --env-file=.env.local --import tsx scripts/seed-p1.ts --dry-run --only agencies --agency-limit all",
    "db:c0:snapshot-pre": "node --env-file=.env.local --import tsx scripts/c0/snapshot-pre-c0.ts",
    "db:c0:backup-pre": "node --env-file=.env.local --import tsx scripts/c0/backup-pre-c0.ts",
    "db:c0:export-castings-pre": "node --env-file=.env.local --import tsx scripts/c0/export-castings-pre-c0.ts",
    "db:seed:c0-teachers": "node --env-file=.env.local --import tsx scripts/c0/seed-teachers.ts",
    "db:seed:c0-teachers:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-teachers.ts --dry-run",
    "db:seed:c0-agencies": "node --env-file=.env.local --import tsx scripts/c0/seed-agencies.ts",
    "db:seed:c0-agencies:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-agencies.ts --dry-run",
    "db:c0:diff-castings": "node --env-file=.env.local --import tsx scripts/c0/diff-castings.ts",
    "db:seed:c0-profiles": "node --env-file=.env.local --import tsx scripts/c0/seed-profiles.ts",
    "db:seed:c0-profiles:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-profiles.ts --dry-run",
    "db:seed:c0-castings": "node --env-file=.env.local --import tsx scripts/c0/seed-castings.ts",
    "db:seed:c0-castings:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-castings.ts --dry-run",
    "db:seed:c0-news": "node --env-file=.env.local --import tsx scripts/c0/seed-news.ts",
    "db:seed:c0-news:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-news.ts --dry-run",
    "db:seed:c0-video-castings": "node --env-file=.env.local --import tsx scripts/c0/seed-video-castings.ts",
    "db:seed:c0-video-castings:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-video-castings.ts --dry-run",
    "db:seed:c0-banners": "node --env-file=.env.local --import tsx scripts/c0/seed-banners.ts",
    "db:seed:c0-banners:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-banners.ts --dry-run",
    "db:seed:c0-teacher-files": "node --env-file=.env.local --import tsx scripts/c0/seed-teacher-files.ts",
    "db:seed:c0-teacher-files:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-teacher-files.ts --dry-run",
    "db:seed:c0-lineups": "node --env-file=.env.local --import tsx scripts/c0/seed-lineups.ts",
    "db:seed:c0-lineups:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-lineups.ts --dry-run",
    "db:seed:c0-movies": "node --env-file=.env.local --import tsx scripts/c0/seed-movies.ts",
    "db:seed:c0-movies:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-movies.ts --dry-run",
    "db:seed:c0-appearances": "node --env-file=.env.local --import tsx scripts/c0/seed-appearances.ts",
    "db:seed:c0-appearances:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-appearances.ts --dry-run",
    "db:seed:c0-appearances-extra": "node --env-file=.env.local --import tsx scripts/c0/seed-appearances-extra.ts",
    "db:seed:c0-appearances-extra:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-appearances-extra.ts --dry-run",
    "db:seed:c0-star-cards": "node --env-file=.env.local --import tsx scripts/c0/seed-star-cards.ts",
    "db:seed:c0-star-cards:dry-run": "node --env-file=.env.local --import tsx scripts/c0/seed-star-cards.ts --dry-run",
    "profiles:images:manifest": "node --env-file=.env.local --import tsx scripts/export-profile-image-manifest.ts --output tmp/profile-image-manifest.json",
    "profiles:images:dry-run": "python3 scripts/download_profile_images_ftp.py --dry-run",
    "profiles:images:sync": "python3 scripts/download_profile_images_ftp.py",
    "profiles:images:apply": "node --env-file=.env.local --import tsx scripts/download-profile-images.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.82.1",
    "@payloadcms/next": "^3.82.1",
    "@payloadcms/richtext-lexical": "^3.82.1",
    "graphql": "^16.13.2",
    "next": "^16.2.3",
    "payload": "^3.82.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
