---
title: 배우앤배움 BNB 전체 메뉴 구조도
---
graph TD
    GATE["🏠 게이트 페이지\n배우앤배움 BNB"]

    GATE --> ART["🎭 아트센터\n성인·데뷔"]
    GATE --> EXAM["📚 입시센터\n대학입시·예고"]
    GATE --> TEEN["⭐ 하이틴센터\n중고생 특화"]
    GATE --> KIDS["🌟 키즈센터\n아역·아동"]
    GATE --> AVE["🌿 애비뉴센터\n40세 이상"]

    %% =====================
    %% 공통 헤더 CTA
    %% =====================
    subgraph HEADER["📌 공통 헤더 (센터 선택 후)"]
        H_CTR["▼ 센터 선택"]
        H_LOGO["BNB 로고"]
        H_AUD["🔴 오디션 지원하기 CTA"]
        H_CON["🟠 무료 상담신청 CTA"]
    end

    ART --> HEADER
    EXAM --> HEADER
    TEEN --> HEADER
    KIDS --> HEADER
    AVE --> HEADER

    %% =====================
    %% GNB 1depth
    %% =====================
    subgraph GNB["GNB — 1depth 메뉴"]
        G1["배우앤배움"]
        G2["교육"]
        G3["캐스팅"]
        G4["매니지먼트"]
        G5["운영"]
        G6["상담센터"]
    end

    HEADER --> GNB

    %% =====================
    %% 1. 배우앤배움 서브메뉴
    %% =====================
    G1 --> A1["회사소개 📄"]
    G1 --> A2["대표인사말 📄\n입시·키즈·하이틴"]
    G1 --> A3["센터소개 📄\n아트센터 전용"]
    G1 --> A4["연혁 📄\n입시센터 전용"]
    G1 --> A5["자회사 안내 📄\n입시센터 전용"]
    G1 --> A6["시설안내 🖼️"]
    G1 --> A7["오시는 길 📄"]

    %% =====================
    %% 2. 교육 서브메뉴
    %% =====================
    G2 --> B1["등급제 교육관리시스템 📄\n아트·키즈·하이틴"]
    G2 --> B2["교육진 소개 🖼️\n전 센터 공통"]
    G2 --> B3["엔터테인먼트 위탁교육 📄\n아트·키즈·하이틴"]
    G2 --> B4["이달의 커리큘럼 📅\n아트·하이틴 Ajax필터"]
    G2 --> B5["하이틴센터 특강 🖼️\n하이틴 전용"]

    G2 --> B_EXAM["입시센터 전용"]
    B_EXAM --> B6["입시반 커리큘럼 📄"]
    B_EXAM --> B7["재입시반 커리큘럼 📄"]
    B_EXAM --> B8["편입반 커리큘럼 📄"]
    B_EXAM --> B9["예비입시반 커리큘럼 📄"]
    B_EXAM --> B10["예고입시반 커리큘럼 📄"]
    B_EXAM --> B11["입시 매니지먼트 📄"]

    G2 --> B_KIDS["키즈센터 전용"]
    B_KIDS --> B12["영재 교육과정 📄"]
    B_KIDS --> B13["아역배우 교육과정 📄"]
    B_KIDS --> B14["아티스트 교육과정 📄"]

    %% =====================
    %% 3. 캐스팅 서브메뉴
    %% =====================
    G3 --> C1["이달의 드라마·광고 출연장면 🖼️\n아트·하이틴·키즈"]
    G3 --> C2["진행중인 캐스팅 출연현황 📋\n아트·하이틴·키즈"]

    G3 --> C_DRAMA["드라마 캐스팅"]
    C_DRAMA --> C3["유캐스팅 📋\n공통"]
    C_DRAMA --> C4["BNB캐스팅 📋\n키즈·하이틴"]
    C_DRAMA --> C5["IMGround 📋\n키즈·하이틴"]

    G3 --> C_AD["광고 캐스팅"]
    C_AD --> C6["BX모델에이전시 📋\n아트·하이틴"]
    C_AD --> C7["다이렉트 캐스팅 🖼️\n하이틴 전용"]

    G3 --> C8["BNB 캐스팅 섭외뉴스 🖼️\n하이틴 전용"]

    G3 --> C_EXAM2["입시센터 전용 — 합격현황"]
    C_EXAM2 --> C9["대학교 합격현황 🖼️"]
    C_EXAM2 --> C10["예술고등학교 합격현황 🖼️"]

    G3 --> C11["오디션 지원하기 📝\n아트·하이틴 — FORM"]

    %% =====================
    %% 4. 매니지먼트 서브메뉴
    %% =====================
    G4 --> D1["매니지먼트 시스템 소개 📄\n아트·하이틴·키즈"]
    G4 --> D2["매니저 소개 📄\n아트센터 전용"]
    G4 --> D3["이달의 촬영·오디션 스케줄 📅\n캘린더형"]
    G4 --> D4["BNB 루키 🖼️\n아트·하이틴"]
    G4 --> D5["BNB출신 아티스트 🖼️\n아트센터 전용"]
    G4 --> D6["아역배우 프로필 🖼️\n키즈센터 전용"]
    G4 --> D7["촬영후기 🖼️\n아트센터 전용"]
    G4 --> D8["프로필 촬영·제작 📄\n아트·하이틴·키즈"]

    G4 --> D_EXAM["입시센터 전용 — 합격자 소개"]
    D_EXAM --> D9["수강생 합격후기 🖼️"]
    D_EXAM --> D10["수강생 합격영상 🖼️"]

    %% =====================
    %% 5. 운영 서브메뉴
    %% =====================
    G5 --> E1["NEWS & NOTICE 📋\n전 센터 공통"]
    G5 --> E2["입학안내 📄\n전 센터 공통"]
    G5 --> E3["학원 100% 소개영상 🔗\nYouTube 외부링크"]
    G5 --> E4["학원 100% 이용법 📄\n전 센터 공통"]
    G5 --> E5["스타카드 멤버십서비스 🖼️\n전 센터 공통"]

    G5 --> E_EXAM["입시센터 전용"]
    E_EXAM --> E6["특별한 시스템 📄"]
    E_EXAM --> E7["멤버십 서비스 📄"]
    E_EXAM --> E8["장학제도 📄"]

    %% =====================
    %% 6. 상담센터 서브메뉴
    %% =====================
    G6 --> F1["CS센터 운영안내 📄\n전 센터 공통"]
    G6 --> F2["온라인 상담신청 📝\n전환 핵심 — FORM"]
    G6 --> F3["온라인 상담현황 📋"]
    G6 --> F4["FAQ 📄"]

    %% =====================
    %% 애비뉴센터 원페이지
    %% =====================
    subgraph AVE_PAGE["🌿 애비뉴센터 — 원페이지 별도 구성"]
        AV1["섹션1: 센터 소개"]
        AV2["섹션2: 제휴업체 (스타카드 파트너)"]
        AV3["섹션3: 강사진 소개"]
        AV4["섹션4: 캐스팅·모집 안내"]
        AV5["📝 상담신청 → 공통 폼 연결"]
        AV1 --> AV2 --> AV3 --> AV4 --> AV5
    end

    AVE --> AVE_PAGE

    %% =====================
    %% 스타일
    %% =====================
    classDef gate fill:#1a1a2e,color:#fff,stroke:#e94560,stroke-width:3px
    classDef center fill:#16213e,color:#fff,stroke:#0f3460,stroke-width:2px
    classDef header fill:#0f3460,color:#fff,stroke:#533483
    classDef gnb fill:#533483,color:#fff,stroke:#e94560
    classDef cta fill:#e94560,color:#fff,stroke:#c23152,stroke-width:2px
    classDef sub fill:#f0f4ff,color:#1a1a2e,stroke:#bbc4f0
    classDef exclusive fill:#fff8e1,color:#5d4037,stroke:#ffb300
    classDef avenue fill:#e8f5e9,color:#1b5e20,stroke:#4caf50

    class GATE gate
    class ART,EXAM,TEEN,KIDS,AVE center
    class H_CTR,H_LOGO header
    class H_AUD,H_CON cta
    class G1,G2,G3,G4,G5,G6 gnb
    class B_EXAM,B_KIDS,C_DRAMA,C_AD,C_EXAM2,D_EXAM,E_EXAM exclusive
    class AVE_PAGE,AV1,AV2,AV3,AV4,AV5 avenue
